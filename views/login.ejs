<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Verses</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <div class="wrap">
    <div class="login-box">
      <h2>Admin Login</h2>
      <% if (error) { %>
        <p class="error-msg"><%= error %></p>
      <% } %>
      <form method="POST" action="/admin/login" style="display:flex; flex-direction:column; gap:12px;">
        <input type="password" name="passcode" placeholder="Passcode" required autofocus>
        <button class="primary" type="submit">Enter</button>
      </form>
      <p style="margin-top:16px;"><a href="/">&larr; Back to poems</a></p>
    </div>
  </div>
</body>
</html>
